# syntax=docker/dockerfile:1
#
# End-to-end test Dockerfile
# Builds openclaw-agent with OpenClaw and fetches config from DynamoDB
#

# ---- Build stage ----
FROM golang:1.24-alpine AS builder

WORKDIR /app

# Copy openclaw-agent source
COPY openclaw-agent/go.mod openclaw-agent/go.sum ./
RUN go mod download

COPY openclaw-agent/ ./

# Build openclaw-agent
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /openclaw-agent ./cmd/server

# Build mock gateways
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /mock-voice-gateway ./test/integration/mock_voice_gateway
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /mock-auth-gateway ./test/integration/mock_auth_gateway

# ---- Runtime stage with OpenClaw ----
FROM alpine/openclaw:2026.3.24

# Switch to root to install dependencies
USER root

# Install Python and boto3 for config fetch script
# Note: alpine/openclaw is actually Debian-based despite the name
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip curl bash jq && \
    pip3 install --no-cache-dir --break-system-packages boto3==1.34.* cryptography==42.* && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Copy binaries from builder stage
COPY --from=builder /openclaw-agent /usr/local/bin/openclaw-agent
COPY --from=builder /mock-voice-gateway /usr/local/bin/mock-voice-gateway
COPY --from=builder /mock-auth-gateway /usr/local/bin/mock-auth-gateway

# Make them executable
RUN chmod +x /usr/local/bin/openclaw-agent \
    /usr/local/bin/mock-voice-gateway \
    /usr/local/bin/mock-auth-gateway

# Copy config fetch scripts
COPY orchestrator/scripts/container/fetch_config.py /opt/scripts/fetch_config.py
COPY orchestrator/scripts/container/entrypoint-e2e.sh /opt/scripts/entrypoint.sh

# Copy OpenClaw config template
COPY openclaw-agent/test/integration/openclaw.json /tmp/openclaw-template.json

# Make scripts executable
RUN chmod +x /opt/scripts/fetch_config.py /opt/scripts/entrypoint.sh

# Create directories with correct permissions
RUN mkdir -p /home/node/.openclaw /home/node/.clawtalk && \
    chown -R node:node /home/node/.openclaw /home/node/.clawtalk && \
    chmod 700 /home/node/.openclaw /home/node/.clawtalk

# Switch back to node user
USER node

# Expose ports
EXPOSE 18789 8080 8789 9090

ENTRYPOINT ["/opt/scripts/entrypoint.sh"]
