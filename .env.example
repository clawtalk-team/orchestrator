# Orchestrator Configuration Example

APP_NAME=orchestrator
DEBUG=true

# Master API key (for testing)
MASTER_API_KEY=test-master-key

# ==============================================================================
# LLM Provider Configuration (REQUIRED for container runtime)
# ==============================================================================
# These are needed to create configs for containers. Containers fetch these from
# DynamoDB but they must be set in user config first (via API or manual setup).

# Anthropic API Key (required for Claude models)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenRouter API Key (optional, for multi-provider access)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenAI API Key (optional, for GPT models)
# Get from: https://platform.openai.com
OPENAI_API_KEY=sk-proj-your-key-here

# ==============================================================================
# DynamoDB Configuration
# ==============================================================================
# For local development (DynamoDB Local)
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_DEFAULT_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# For AWS (production/testing) - comment out DYNAMODB_ENDPOINT and set real creds
# AWS_DEFAULT_REGION=ap-southeast-2
# Use AWS CLI configured profile or set these:
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# DynamoDB Table
CONTAINERS_TABLE=openclaw-containers

# ==============================================================================
# OpenClaw Gateway Configuration
# ==============================================================================
# Token for OpenClaw gateway authentication
# For testing, use a simple token. In production, this should be secure.
OPENCLAW_GATEWAY_TOKEN=test-token-123

# Default LLM model for containers
OPENCLAW_MODEL=claude-3-haiku-20240307

# LLM Provider (anthropic, openrouter, openai)
LLM_PROVIDER=anthropic

# ==============================================================================
# ECS Configuration
# ==============================================================================
ECS_CLUSTER_NAME=clawtalk-orchestrator-dev
ECS_TASK_DEFINITION=openclaw-agent
ECS_CONTAINER_NAME=openclaw-agent

# ==============================================================================
# Auth Gateway Configuration
# ==============================================================================
# For local testing with mocks
AUTH_GATEWAY_URL=http://localhost:8789

# For production/integration testing
# AUTH_GATEWAY_URL=https://auth-gateway.clawtalk.com

# ==============================================================================
# Encryption (optional, for production)
# ==============================================================================
# Encryption key for sensitive data in DynamoDB
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=your-base64-encryption-key-here

# ==============================================================================
# SSM Parameter Store (deprecated, use DynamoDB instead)
# ==============================================================================
SSM_PREFIX=/clawtalk/orchestrator
