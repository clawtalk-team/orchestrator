# Orchestrator AWS Configuration
# All services running in AWS (Lambda, DynamoDB, ECS)

APP_NAME=orchestrator
DEBUG=false

# ==============================================================================
# AWS Configuration (REQUIRED)
# ==============================================================================
AWS_DEFAULT_REGION=ap-southeast-2
AWS_PROFILE=personal
# Or use explicit credentials:
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ==============================================================================
# DynamoDB Configuration (AWS)
# ==============================================================================
DYNAMODB_REGION=ap-southeast-2
CONTAINERS_TABLE=openclaw-containers
# DO NOT set DYNAMODB_ENDPOINT - let boto3 use real AWS DynamoDB

# ==============================================================================
# Gateway URLs (AWS Lambda)
# ==============================================================================
# Auth Gateway Lambda
AUTH_GATEWAY_URL=https://z1fm1cdkph.execute-api.ap-southeast-2.amazonaws.com

# Orchestrator Lambda
# ORCHESTRATOR_URL=https://prz6mum7c7.execute-api.ap-southeast-2.amazonaws.com

# Voice Gateway (ELB)
VOICE_GATEWAY_URL=http://voice-gateway-dev-544339776.ap-southeast-2.elb.amazonaws.com

# ==============================================================================
# ECS Configuration (AWS Fargate)
# ==============================================================================
ECS_CLUSTER_NAME=clawtalk-dev
ECS_TASK_DEFINITION=openclaw-agent-dev
ECS_CONTAINER_NAME=openclaw-agent

# VPC Configuration for ECS tasks
# Private subnets (no public IP)
ECS_SUBNETS=subnet-0123456789abcdef0,subnet-0123456789abcdef1
ECS_SECURITY_GROUPS=sg-0123456789abcdef0

# ==============================================================================
# LLM Provider API Keys
# ==============================================================================
# These are stored in DynamoDB user configs, but set here for defaults

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenRouter API Key (optional)
OPENROUTER_API_KEY=sk-or-v1-...

# OpenAI API Key (optional)
OPENAI_API_KEY=sk-proj-...

# ==============================================================================
# OpenClaw Gateway Configuration
# ==============================================================================
OPENCLAW_GATEWAY_TOKEN=test-token-123
OPENCLAW_MODEL=claude-3-haiku-20240307
LLM_PROVIDER=anthropic

# ==============================================================================
# Master API Key (for admin operations)
# ==============================================================================
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
MASTER_API_KEY=your-master-api-key-here
